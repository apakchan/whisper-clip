{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/.github/tauri-conf-schema.json",
  "productName": "whisper-clip",
  "version": "0.1.0",
  "identifier": "com.whisper-clip",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": []
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": "Entitlements.plist",
      "signingIdentity": "-"
    },
    "targets": ["dmg"]
  }
}
